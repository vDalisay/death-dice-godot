{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install & Build godot-mcp",
      "type": "shell",
      "command": "cd Mcp\\godot-mcp ; npm install ; npm run build",
      "problemMatcher": []
    },
    {
      "label": "Run godot-mcp",
      "type": "shell",
      "command": "cd Mcp\\godot-mcp ; pwsh -File .\\run-godot-mcp.ps1 -GodotPath '${input:godotPath}'",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    }
    ,
    {
      "label": "Run godot-mcp (build)",
      "type": "shell",
      "command": "cd Mcp\\godot-mcp ; pwsh -File .\\run-godot-mcp-build.ps1 -GodotPath '${input:godotPath}'",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    }
  ],
  "inputs": [
    {
      "id": "godotPath",
      "type": "promptString",
      "description": "Full path to Godot executable (e.g. C:\\Program Files\\Godot\\Godot.exe)",
      "default": ""
    }
  ]
}
