[gd_scene format=3]

[node name="ShopItemCard" type="PanelContainer"]
layout_mode = 2
custom_minimum_size = Vector2(220, 220)

[node name="VBoxContainer" type="VBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 0

[node name="AccentBar" type="ColorRect" parent="VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(0, 6)
color = Color(0.27451, 0.533333, 1, 1)

[node name="MarginContainer" type="MarginContainer" parent="VBoxContainer"]
layout_mode = 2
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 12

[node name="Content" type="VBoxContainer" parent="VBoxContainer/MarginContainer"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="NameLabel" type="Label" parent="VBoxContainer/MarginContainer/Content"]
layout_mode = 2
text = "Item"
autowrap_mode = 3
horizontal_alignment = 1

[node name="KeywordLabel" type="Label" parent="VBoxContainer/MarginContainer/Content"]
layout_mode = 2
text = "Keywords"
autowrap_mode = 3
horizontal_alignment = 1

[node name="Spacer" type="Control" parent="VBoxContainer/MarginContainer/Content"]
layout_mode = 2
size_flags_vertical = 3

[node name="FooterRow" type="HBoxContainer" parent="VBoxContainer/MarginContainer/Content"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="PriceLabel" type="Label" parent="VBoxContainer/MarginContainer/Content/FooterRow"]
layout_mode = 2
text = "G 0"
vertical_alignment = 1

[node name="FooterSpacer" type="Control" parent="VBoxContainer/MarginContainer/Content/FooterRow"]
layout_mode = 2
size_flags_horizontal = 3

[node name="BuyButton" type="Button" parent="VBoxContainer/MarginContainer/Content/FooterRow"]
layout_mode = 2
custom_minimum_size = Vector2(120, 44)
text = "Buy"
